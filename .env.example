# =============================================================================
# HOMS — Frontend environment (Vite)
# Copy to `.env` or `.env.local` and fill in real values.
# NEVER commit `.env` or `.env.local`.
# =============================================================================

# Supabase (Dashboard → Project Settings → API)
# Anon key is safe for browser use; RLS protects data.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# WordPress / LearnDash (optional — used by legacy frontend WP helpers)
VITE_WP_API_URL=https://your-wordpress-site.com/wp-json
VITE_WP_USERNAME=your_wp_username
VITE_WP_APP_PASSWORD=your_wp_application_password

# =============================================================================
# Edge Function secrets — set in Supabase Dashboard → Edge Functions → Secrets
# (NOT in this file for production; listed here for local reference only)
# =============================================================================
#
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key          # server-only, never expose to frontend
# PGCRYPTO_ENCRYPTION_KEY=your_pgcrypto_passphrase         # encrypts tenant connector keys at rest
#
# ALLOWED_ORIGIN_1=http://localhost:5173
# ALLOWED_ORIGIN_2=
#
# JOTFORM_API_KEY=                                         # legacy global key; prefer per-tenant settings
# ANTHROPIC_API_KEY=
# AI_GATEWAY_URL=https://your-ai-worker.workers.dev
# AI_GATEWAY_API_KEY=
#
# PLATFORM_BREVO_API_KEY=                               # current legacy request-access provider; do not use for new offer delivery paths
# REQUEST_ACCESS_NOTIFICATION_TO=ops@example.com
# REQUEST_ACCESS_FROM_EMAIL=noreply@example.com
# REQUEST_ACCESS_FROM_NAME=HOMS Access Requests
# REQUEST_ACCESS_RATE_LIMIT_WINDOW_MINUTES=60
# REQUEST_ACCESS_RATE_LIMIT_MAX_PER_EMAIL=3
# REQUEST_ACCESS_RATE_LIMIT_MAX_PER_IP=10
#
# =============================================================================
# Local Edge Function dev only (supabase/functions/.env — also gitignored)
# =============================================================================
#
# Copy the Edge Function block above into supabase/functions/.env when running:
#   supabase functions serve
